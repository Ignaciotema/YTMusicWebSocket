{
  "manifest_version": 3,

  "name": "YTMusic Controller",
  "version": "1.0",

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://music.youtube.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}